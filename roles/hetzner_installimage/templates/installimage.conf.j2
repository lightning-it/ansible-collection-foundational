#jinja2: trim_blocks: False, lstrip_blocks: True
# Generated by lit.foundational.hetzner_installimage.
# This file is destructive when passed to installimage.
{% for disk in hetzner_installimage_system_disks %}
DRIVE{{ loop.index }} {{ disk.path }}
{% endfor %}

SWRAID {{ hetzner_installimage_layout.software_raid.enabled | ternary(1, 0) }}
{% if hetzner_installimage_layout.software_raid.enabled | bool %}
SWRAIDLEVEL {{ hetzner_installimage_layout.software_raid.level }}
{% endif %}
BOOTLOADER {{ hetzner_installimage_layout.bootloader }}
HOSTNAME {{ hetzner_installimage_hostname }}
IPV4_ONLY {{ hetzner_installimage_layout.ipv4_only | ternary(1, 0) }}
FORCE_GPT {{ hetzner_installimage_layout.force_gpt | ternary(1, 0) }}
TAKE_OVER_RESCUE_SYSTEM_SSH_PUBLIC_KEYS {{ hetzner_installimage_take_over_rescue_ssh_public_keys | ternary('yes', 'no') }}

{% for partition in hetzner_installimage_layout.partitions %}
PART {{ partition.mountpoint }} {{ partition.filesystem }} {{ partition.size }}{% if partition.crypt | default(false) | bool %} crypt{% endif %}
{% endfor %}
{% for logical_volume in hetzner_installimage_layout.logical_volumes %}
LV {{ logical_volume.volume_group }} {{ logical_volume.name }} {{ logical_volume.mountpoint }} {{ logical_volume.filesystem }} {{ logical_volume.size }}
{% endfor %}

IMAGE {{ hetzner_installimage_image }}
{% if hetzner_installimage_encryption_requested | bool %}
CRYPTPASSWORD {{ hetzner_installimage_template_crypt_password }}
{% endif %}
